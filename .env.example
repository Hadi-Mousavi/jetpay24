# -------------------------------------------------------
# JetPay24 — Environment Variables Template
# -------------------------------------------------------
# Copy this file to .env and fill in your local values.
# Never commit .env to version control.
# -------------------------------------------------------

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=jetpay24
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_HOST=localhost
DB_PORT=5432

# Media (public — KYC images, avatars, guide images)
MEDIA_URL=/media/

# Private media — order attachment files.
# This directory must NOT have a web-server alias.
# Default: BASE_DIR / 'private_media'  (relative to project root)
# In production, set this to an absolute path outside the document root.
# Example: /var/private/jetpay24/order_files/
# PRIVATE_MEDIA_ROOT=/var/private/jetpay24/order_files/
